# App
NODE_ENV=development
DOMAIN=localhost
APP_URL=http://localhost

# API
API_PORT=4000
JWT_SECRET=change_me_to_a_long_random_string
JWT_EXPIRES_IN=7d
JWT_GUEST_EXPIRES_IN=1d
REFRESH_TOKEN_SECRET=change_me_to_another_long_random_string
ADMIN_JWT_SECRET=change_me_to_admin_specific_secret

# Game Engine
GAME_ENGINE_PORT=4001

# Public Room Auto-fill
# Seconds to wait before filling vacant opponent slots with computer players
# Set to 0 to disable auto-fill
ROOM_AUTOFILL_WAIT_SECONDS=3
# Difficulty assigned to auto-filled computer players (easy | medium | hard)
ROOM_AUTOFILL_DIFFICULTY=medium

# PostgreSQL
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=bandrang
POSTGRES_USER=bandrang_user
POSTGRES_PASSWORD=change_me

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# Email (SMTP)
SMTP_HOST=postfix
SMTP_PORT=25
SMTP_FROM=noreply@bandrang.com

# Frontend (public env vars)
NEXT_PUBLIC_API_URL=http://localhost/api/v1
NEXT_PUBLIC_WS_URL=http://localhost
