{
  "name": "band-rang-game-engine",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only --poll src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "jest --runInBand",
    "test:watch": "jest --watch"
  },
  "dependencies": {
    "socket.io": "4.7.5",
    "jsonwebtoken": "9.0.2",
    "ioredis": "5.4.1",
    "pg": "8.12.0",
    "uuid": "10.0.0"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "9.0.6",
    "@types/pg": "8.11.6",
    "@types/uuid": "10.0.0",
    "@types/node": "20.14.12",
    "typescript": "5.5.4",
    "ts-node-dev": "2.0.0",
    "jest": "29.7.0",
    "ts-jest": "29.2.5",
    "@types/jest": "29.5.12"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": ["**/__tests__/**/*.test.ts"],
    "moduleFileExtensions": ["ts", "js"]
  }
}
